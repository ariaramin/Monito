<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetEnd="@+id/end"
        motion:constraintSetStart="@id/start"
        motion:duration="1300"
        motion:motionInterpolator="anticipate">
    </Transition>

    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@+id/nextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintBottom_toTopOf="@+id/guideline2"
            motion:layout_constraintEnd_toStartOf="@id/guideline6"
            motion:layout_constraintStart_toEndOf="@id/guideline5"
            motion:layout_constraintTop_toTopOf="@+id/guideline2">
            <CustomAttribute
                motion:attributeName="text"
                motion:customStringValue="@string/start" />
        </Constraint>
        <Constraint
            android:id="@+id/skipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0"
            motion:layout_constraintBottom_toTopOf="@+id/guideline2"
            motion:layout_constraintEnd_toStartOf="@id/guideline6"
            motion:layout_constraintStart_toStartOf="@id/guideline5"
            motion:layout_constraintTop_toTopOf="@+id/guideline2" />
        <Constraint
            android:id="@+id/dotsIndicator"
            motion:layout_constraintEnd_toEndOf="@id/guideline6"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintBottom_toBottomOf="@id/guideline2"
            motion:layout_constraintTop_toTopOf="@id/guideline2"
            motion:layout_constraintStart_toStartOf="@id/guideline5"
            android:alpha="0" />
        <Constraint />
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
        <Constraint
            android:id="@+id/nextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintBottom_toTopOf="@+id/guideline2"
            motion:layout_constraintTop_toTopOf="@+id/guideline2"
            motion:layout_constraintEnd_toStartOf="@id/guideline6">
            <CustomAttribute
                motion:attributeName="text"
                motion:customStringValue="@string/next" />
        </Constraint>
        <Constraint
            android:id="@+id/skipButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintBottom_toTopOf="@+id/guideline2"
            motion:layout_constraintTop_toTopOf="@+id/guideline2"
            motion:layout_constraintStart_toStartOf="@id/guideline5">
            <CustomAttribute
                motion:attributeName="enabled"
                motion:customBoolean="true" />
        </Constraint>
        <Constraint
            android:id="@+id/dotsIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintBottom_toBottomOf="@id/guideline2"
            motion:layout_constraintTop_toTopOf="@id/guideline2"
            android:alpha="1"
            motion:layout_constraintEnd_toStartOf="@id/nextButton"
            motion:layout_constraintStart_toEndOf="@id/skipButton" />
    </ConstraintSet>
</MotionScene>